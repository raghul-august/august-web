# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=health_library
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Connection URL
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/health_library 

# Algolia 
NEXT_PUBLIC_ALGOLIA_APP_ID=your_application_id
NEXT_PUBLIC_ALGOLIA_API_KEY=your_algolia_search_only_api_key
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=Health-Library

# Gemini AI (for PAA question generation)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-model-name       # 3.1-flash-lite

# Online doctor consult flat self-pay price, whole USD only (no decimals)
NEXT_PUBLIC_CONSULT_PRICE_USD=39 